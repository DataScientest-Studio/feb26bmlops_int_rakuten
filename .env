# Required
BEST_MODEL_PATH=./models/image/resnet50_latest.model
BEST_MODEL_TYPE=resnet50
NUM_CLASSES=27

# Optional — path to classes.json used by the loaded model
CLASSES_JSON_PATH=./models/classes.json

# Fixed data paths for training
DATA_TRAIN=./data/image_db/train
DATA_TEST=./data/image_db/val
IMG_BATCH_SIZE=128
IMG_NUM_WORKERS=0

# Where training sessions are saved
EXPERIMENTS_DIR=./models
#experiments

#DagsHub repo
DAGSHUB_REPO=feb26bmlops_int_rakuten

#db inside the docker network
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/dst_db
